@page
@model Website.Pages.Private.PlanningModel
@{
    ViewData["Title"] = "Planning";
}

<h1>Planning</h1>
<p class="text-muted">
    Steps grouped by Domain and Project, sorted by Priority then Start Date.
    <br /><a asp-page="/Private/DailyTasks">DailyTasks</a>
</p>

<!-- Search and filter controls -->
<div class="mb-3">
    <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
        <div class="input-group" style="max-width: 300px;">
            <input type="text" class="form-control form-control-sm" name="SearchText"
                   value="@Model.SearchText" placeholder="Search steps..." />
            <button type="submit" class="btn btn-sm btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(Model.SearchText))
            {
                <a asp-page="/Private/Planning" asp-route-ShowCompleted="@Model.ShowCompleted"
                   class="btn btn-sm btn-outline-danger" title="Clear search">&times;</a>
            }
        </div>
        <div class="form-check">
            <input type="checkbox" class="form-check-input" id="ShowCompleted"
                   name="ShowCompleted" value="true"
                   checked="@(Model.ShowCompleted ? "checked" : null)"
                   onchange="this.form.submit()" />
            <label class="form-check-label" for="ShowCompleted">Show completed</label>
        </div>
        <noscript><button type="submit" class="btn btn-sm btn-primary">Apply</button></noscript>
    </form>
</div>

@if (Model.TotalSteps == 0)
{
    <div class="alert alert-info">
        No steps to display.
    </div>
}
else
{
    <p>
        <strong>@Model.TotalSteps</strong> step@(Model.TotalSteps != 1 ? "s" : "")
        @if (!string.IsNullOrEmpty(Model.SearchText))
        {
            <span class="text-muted"> matching &ldquo;@Model.SearchText&rdquo;</span>
        }
    </p>

    @foreach (var domain in Model.Domains)
    {
        <h3 class="mt-4 mb-3">@domain.DomainTitle</h3>

        @foreach (var project in domain.Projects)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0 d-inline">@project.ProjectTitle</h5>
                    @if (project.GoalTitle != null)
                    {
                        <small class="text-muted ms-2">Goal: @project.GoalTitle</small>
                    }
                    <span class="float-end">
                        <span class="badge bg-success">@project.StepsComplete complete</span>
                        <span class="badge bg-primary">@project.StepsActive active</span>
                        <span class="badge bg-secondary">@project.StepsDeferred deferred</span>
                    </span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 50px;"></th>
                                <th style="width: 50px;"></th>
                                <th style="width: 80px;">Priority</th>
                                <th>Start Date</th>
                                <th>Status</th>
                                <th>Title</th>
                                <th>Comments</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var today = DateOnly.FromDateTime(DateTime.Today);
                            }
                            @foreach (var step in project.Steps)
                            {
                                var isActive = !step.IsComplete && step.StartDate <= today;
                                var isDeferred = !step.IsComplete && step.StartDate > today;
                                var rowClass = step.IsComplete ? "table-light text-muted" : isActive ? "" : "text-muted";
                                <tr class="@rowClass">
                                    <td class="text-center">
                                        @if (!step.IsComplete)
                                        {
                                            <a asp-page="/Data/Steps/Edit"
                                                   asp-route-id="@step.Id"
                                                   asp-route-returnurl="/Private/Planning"
                                                   class="btn btn-sm btn-outline-primary"
                                                   title="Edit">
                                                &#x270E;
                                            </a>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!step.IsComplete)
                                        {
                                            <form method="post" asp-page-handler="Complete">
                                                <input type="hidden" name="id" value="@step.Id" />
                                                <input type="hidden" name="ShowCompleted" value="@Model.ShowCompleted" />
                                                <input type="hidden" name="SearchText" value="@Model.SearchText" />
                                                <div class="form-check form-switch d-flex justify-content-center mb-0">
                                                    <input class="form-check-input" type="checkbox" role="switch"
                                                           title="Mark complete"
                                                           onchange="if(confirm('Mark this task as complete?')) { this.closest('form').submit(); } else { this.checked = false; }" />
                                                </div>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">&#x2714;</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!step.IsComplete)
                                        {
                                            <form method="post" asp-page-handler="ChangePriority">
                                                <input type="hidden" name="id" value="@step.Id" />
                                                <input type="hidden" name="ShowCompleted" value="@Model.ShowCompleted" />
                                                <input type="hidden" name="SearchText" value="@Model.SearchText" />
                                                <select name="newPriority" class="form-select form-select-sm"
                                                        style="width: 70px;"
                                                        onchange="this.closest('form').submit();">
                                                    @for (int p = 1; p <= 5; p++)
                                                    {
                                                        <option value="@p" selected="@(step.Priority == p ? "selected" : null)">@p</option>
                                                    }
                                                </select>
                                            </form>
                                        }
                                        else
                                        {
                                            @step.Priority
                                        }
                                    </td>
                                    <td>@step.StartDate.ToString("d MMM yyyy")</td>
                                    <td>
                                        @if (step.IsComplete)
                                        {
                                            <span class="badge bg-success">Complete</span>
                                        }
                                        else if (isActive)
                                        {
                                            <span class="badge bg-primary">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Deferred</span>
                                        }
                                    </td>
                                    <td>
                                        @if (step.IsComplete)
                                        {
                                            <s>@step.Title</s>
                                        }
                                        else
                                        {
                                            @step.Title
                                        }
                                    </td>
                                    <td><small class="text-muted">@step.Comments</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}