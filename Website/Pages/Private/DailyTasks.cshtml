@page
@model Website.Pages.Private.Steps.DailyTasksModel
@{
    ViewData["Title"] = "Daily Tasks";
}

<h1>Daily Tasks</h1>
<p class="text-muted">
    Showing incomplete steps with start date on or before @DateOnly.FromDateTime(DateTime.Today).ToString("d MMMM yyyy")
    <br /><a asp-page="/Private/Planning">Planning</a>
</p>

<!-- New Step button -->
<div class="mb-3">
    <a asp-page="/Private/Steps/Create"
       asp-route-returnurl="/Private/DailyTasks"
       class="btn btn-sm btn-success">+ New Step</a>
</div>
<!-- Priority filter -->
<div class="mb-3">
    <form method="get" class="d-inline-flex align-items-center gap-2">
        <label for="MaxPriority" class="form-label mb-0 fw-bold">Filter by priority:</label>
        <select name="MaxPriority" id="MaxPriority" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
            <option value="">All priorities</option>
            <option value="1" selected="@(Model.MaxPriority == 1 ? "selected" : null)">Priority 1 only</option>
            <option value="2" selected="@(Model.MaxPriority == 2 ? "selected" : null)">Priority 1 &amp; 2</option>
            <option value="3" selected="@(Model.MaxPriority == 3 ? "selected" : null)">Priority 1, 2 &amp; 3</option>
        </select>
        <noscript><button type="submit" class="btn btn-sm btn-primary">Apply</button></noscript>
    </form>
</div>

@if (Model.TotalCount == 0)
{
    <div class="alert alert-success">
        <strong>All clear!</strong> No tasks due today or overdue.
    </div>
}
else
{
    <p><strong>@Model.TotalCount</strong> task@(Model.TotalCount != 1 ? "s" : "")</p>

    @foreach (var group in Model.GroupedSteps)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">Priority @group.Key <span class="badge bg-secondary">@group.Count()</span></h5>
            </div>
            <div class="card-body">
                <div class="step-list">
                    <div class="step-head">
                        <div></div>
                        <div></div>
                        <div>Priority</div>
                        <div>Context</div>
                        <div>Start</div>
                        <div>Task</div>
                        <div>Comments</div>
                    </div>

                    @{
                        var today = DateOnly.FromDateTime(DateTime.Today);
                    }
                    @foreach (var step in group)
                    {
                        var isOverdue = step.StartDate < today;

                        <div class="step-row @(isOverdue ? "step-row--overdue" : null)">
                            <div class="cell-action" data-label="">
                                <a asp-page="/Private/Steps/Edit"
                                   asp-route-id="@step.Id"
                                   asp-route-returnurl="/Private/DailyTasks"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Edit">
                                    &#x270E;
                                </a>
                            </div>

                            <div class="cell-action" data-label="">
                                <form method="post" asp-page-handler="Complete">
                                    <input type="hidden" name="id" value="@step.Id" />
                                    <input type="hidden" name="MaxPriority" value="@Model.MaxPriority" />
                                    <div class="form-check form-switch d-flex justify-content-center mb-0">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                               title="Mark complete"
                                               onchange="if(confirm('Mark this task as complete?')) { this.closest('form').submit(); } else { this.checked = false; }" />
                                    </div>
                                </form>
                            </div>

                            <div data-label="Priority">
                                <form method="post" asp-page-handler="ChangePriority">
                                    <input type="hidden" name="id" value="@step.Id" />
                                    <input type="hidden" name="MaxPriority" value="@Model.MaxPriority" />
                                    <select name="newPriority" class="form-select form-select-sm"
                                            style="width: 70px;"
                                            onchange="this.closest('form').submit();">
                                        @for (int p = 1; p <= 5; p++)
                                        {
                                            <option value="@p" selected="@(step.Priority == p ? "selected" : null)">@p</option>
                                        }
                                    </select>
                                </form>
                            </div>

                            <div data-label="Context">
                                @step.Domain?.Title
                                @if (step.Project != null)
                                {
                                    <span class="text-muted">&middot; @step.Project.Title</span>
                                }
                            </div>

                            <div data-label="Start">@step.StartDate.ToString("d MMM yyyy")</div>

                            <div data-label="Task">@step.Title</div>

                            <div data-label="Comments">
                                <small class="text-muted">@step.Comments</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
