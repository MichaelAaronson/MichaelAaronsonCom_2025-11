@page
@model Website.Pages.ResumeModel
<style>
    h1 {text-align:center}
    table td {
        border-width: 2px;
        //text-align: center;
    }
    @@media print {
        .no-print, header, nav {
            display: none;
        }
    }
</style>
@{
    ViewData["Title"] = "Resume";
}

<p>
    Michael Aaronson
    <br />Michael@MichaelAaronson.com
    <br />027 242 0599
    <br />@DateTime.Now.ToString("MMMM yyyy")
    <br /><a href="javascript:window.print()" class="no-print">Save as PDF</a>
</p>

<h1>Resume</h1>

<form method="get" class="no-print mb-3">
    <label for="startYear">Show jobs starting from year:</label>
    <input type="number" name="startYear" id="startYear"
           value="@Model.StartYear" min="1960" max="2026" />
    <button type="submit">Filter</button>
    <a asp-page="Resume">All</a>
</form>

@await Component.InvokeAsync("ContentBlock", new { key = "resume-education" })

<h2>Experience</h2>

@if (Model.Jobs == null || !Model.Jobs.Any())
{
    <p>No job history found.</p>
}
else
{
    @foreach (var job in Model.Jobs)
    {
        <div>
                <p>
                    <strong>@job.Role</strong>
                    <br />
                    @job.Company
                    @if (!string.IsNullOrEmpty(job.Location))
                    {
                        <text> &mdash; @job.Location</text>
                    }
                    <br />
                    @job.StartAndEndDate
                    @* @job.Duration *@
                    
                    @if (job.JobDetails != null && job.JobDetails.Any())
                    {
                        <ul>
                            @foreach (var detail in job.JobDetails)
                            {
                                <li>@detail.Description</li>
                            }
                        </ul>
                    }
                </p>
        </div>
    }
}
