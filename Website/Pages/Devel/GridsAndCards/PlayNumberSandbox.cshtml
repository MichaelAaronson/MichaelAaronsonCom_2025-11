<div class="grid-list">
    <div class="grid-row grid-head">
        <div>Name</div>
        <div>Value</div>
        <div></div>
    </div>

    @foreach (var item in Model.PlayNumbers)
    {
        <div class="grid-row">
            <div data-label="Name">@item.Name</div>
            <div data-label="Value">@item.Value</div>
            <div><a href="#">Edit</a></div>
        </div>
    }
</div>

