@page
@model Website.Pages.Data.Persons.ImageManagerModel

@{
    ViewData["Title"] = "Image Manager";
}

<h1>Image Manager</h1>
<p>Images folder: /Images/Persons/</p>

<h2>Upload Image</h2>
<form method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="imageFile" class="form-label">Select image file</label>
        <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*" style="max-width: 400px;" />
    </div>
    <button type="submit" class="btn btn-primary">Upload</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info mt-3" style="max-width: 400px;">@Model.Message</div>
}

@if (!string.IsNullOrEmpty(Model.DiagFilename))
{
    <h2 class="mt-4">All Metadata: @Model.DiagFilename</h2>
    @if (Model.DiagTags.Count == 0)
    {
        <p>No metadata found in this image.</p>
    }
    else
    {
        <p>@Model.DiagTags.Count tags found.</p>
        <table class="table table-sm" style="max-width: 900px;">
            <thead>
                <tr>
                    <th>Directory</th>
                    <th>Tag</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model.DiagTags)
                {
                    <tr>
                        <td>@tag.Directory</td>
                        <td>@tag.TagName</td>
                        <td>@(tag.Value ?? "(null)")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <a href="/Data/Persons/ImageManager" class="btn btn-secondary mb-3">Close Metadata</a>
}

<h2 class="mt-4">Current Images (@Model.Images.Count)</h2>

@if (Model.Images.Count == 0)
{
    <p>No images found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Filename</th>
                <th>Size</th>
                <th>Description</th>
                <th>Date Taken</th>
                <th>Preview</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var image in Model.Images)
            {
                <tr>
                    <td style="vertical-align: middle;">@image.Filename</td>
                    <td style="vertical-align: middle;">@image.SizeKb KB</td>
                    <td style="vertical-align: middle;">@(image.Description ?? "—")</td>
                    <td style="vertical-align: middle;">@(image.DateTaken ?? "—")</td>
                    <td>
                        <img src="~/Images/Persons/@image.Filename" alt="@image.Filename" style="max-height: 100px;" />
                    </td>
                    <td style="vertical-align: middle;">
                        <a href="/Data/Persons/ImageManager?handler=Diag&filename=@image.Filename" class="btn btn-sm btn-outline-secondary me-1">Metadata</a>
                        <form method="post" asp-page-handler="Delete" style="display:inline;">
                            <input type="hidden" name="filename" value="@image.Filename" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete @image.Filename?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
