@page
@model Website.Pages.Data.PersonImages.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>PersonImage</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="PersonImage.PersonId" class="control-label"></label>
                <select asp-for="PersonImage.PersonId" class ="form-control" asp-items="ViewBag.PersonId" ></select>
            </div>
            <div class="form-group">
                <label asp-for="PersonImage.ImageId" class="control-label"></label>
                <select asp-for="PersonImage.ImageId" class ="form-control" asp-items="ViewBag.ImageId" ></select>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="PersonImage.IsMainImage" /> @Html.DisplayNameFor(model => model.PersonImage.IsMainImage)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
