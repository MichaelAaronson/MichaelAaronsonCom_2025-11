@page
@model Website.Pages.Data.JobSkills.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>JobSkill</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="JobSkill.Id" />
            <div class="form-group">
                <label asp-for="JobSkill.Title" class="control-label"></label>
                <input asp-for="JobSkill.Title" class="form-control" />
                <span asp-validation-for="JobSkill.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="JobSkill.Version" class="control-label"></label>
                <input asp-for="JobSkill.Version" class="form-control" />
                <span asp-validation-for="JobSkill.Version" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="JobSkill.Comments" class="control-label"></label>
                <input asp-for="JobSkill.Comments" class="form-control" />
                <span asp-validation-for="JobSkill.Comments" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="JobSkill.Summary" class="control-label"></label>
                <textarea asp-for="JobSkill.Summary" class="form-control" rows="5" style="resize: vertical;"></textarea>
                <span asp-validation-for="JobSkill.Summary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
