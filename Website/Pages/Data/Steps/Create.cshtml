@page
@model Website.Pages.StepPages.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Step</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Step.Priority" class="control-label"></label>
                <input asp-for="Step.Priority" class="form-control" />
                <span asp-validation-for="Step.Priority" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.StartDate" class="control-label"></label>
                <input asp-for="Step.StartDate" class="form-control" />
                <span asp-validation-for="Step.StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.IsComplete" class="control-label"></label>
                <input asp-for="Step.IsComplete" class="form-check-input" />
                <span asp-validation-for="Step.IsComplete" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Step.Title" class="control-label"></label>
                <input asp-for="Step.Title" class="form-control" aria-required="true"/>
                <span asp-validation-for="Step.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.Comments" class="control-label"></label>
                <input asp-for="Step.Comments" class="form-control" />
                <span asp-validation-for="Step.Comments" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.ProjectId" class="control-label"></label>
                <input asp-for="Step.ProjectId" class="form-control" />
                <span asp-validation-for="Step.ProjectId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.Project" class="control-label"></label>
                <input asp-for="Step.Project" class="form-control" />
                <span asp-validation-for="Step.Project" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.DomainId" class="control-label"></label>
                <input asp-for="Step.DomainId" class="form-control" />
                <span asp-validation-for="Step.DomainId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Step.Domain" class="control-label"></label>
                <input asp-for="Step.Domain" class="form-control" />
                <span asp-validation-for="Step.Domain" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
